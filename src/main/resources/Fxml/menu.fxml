<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ComboBox?>
<VBox alignment="CENTER" prefHeight="194.0" prefWidth="277.0" spacing="5" style="-fx-border-color: gray; -fx-padding: 10;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cw1.menuController">

    <Label fx:id="foodName" style="-fx-font-weight: bold;" text="Food Name" />
    <Label fx:id="prod_price" text="0.00" />

    <ImageView fx:id="prod_Image" fitHeight="153.0" fitWidth="166.0" />

    <HBox alignment="CENTER" spacing="10">
        <ComboBox fx:id="prod_dropdown" prefWidth="80" />
        <Button fx:id="addButton" onAction="#addButton" text="Add" />
    </HBox>
</VBox>
